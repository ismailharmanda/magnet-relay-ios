# Local fallback only. GitHub Actions should use repository secrets instead.
# Do not commit real values in .env.release.

APP_STORE_CONNECT_KEY_ID=
APP_STORE_CONNECT_ISSUER_ID=

# Preferred for GitHub Actions and portable local shells:
APP_STORE_CONNECT_KEY_P8_BASE64=

# Optional local fallback:
APP_STORE_CONNECT_KEY_PATH=

# Optional override if ASC already has build 1.
FLUX_RELAY_BUILD_NUMBER=
